                  "const json = pm.response.json();",
                  "const list = json.results ? json.results : json;",
                  "const notif = list.find(n => n.notification_type === \"bid_outbid\" && n.auction === Number(pm.environment.get(\"auction_id\")));",
                  "pm.expect(notif).to.exist;",
                  "if (notif) {",
                  "  pm.environment.set(\"outbid_notification_id\", notif.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Token {{bidder1_token}}"
              }
            ],
            "url": "{{base_url}}/api/notifications/",
            "description": "Verify bidder 1 received an outbid notification."
          },
